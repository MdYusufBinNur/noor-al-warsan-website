# Resend API Key for sending quote request emails
RESEND_API_KEY=re_1234567890

# The email address that will receive the quote request notifications
CONTACT_RECEIVER_EMAIL=info@nooralwarsan.ae

# The sender email address (Resend requires domain verification. If not verified, use onboarding@resend.dev)
CONTACT_SENDER_EMAIL=onboarding@resend.dev

# Public Contact Information (for frontend display)
NEXT_PUBLIC_CONTACT_EMAIL=info@nooralwarsan.ae
NEXT_PUBLIC_CONTACT_PHONE="+971 4 123 4567"
NEXT_PUBLIC_CONTACT_ADDRESS="Al Warsan Industrial Area, Dubai, UAE"

# WhatsApp Mobile Number (in international format, e.g., 971501234567, without + or leading zeros)
NEXT_PUBLIC_WHATSAPP_NUMBER=971501234567
